# ─── Supabase (même projet pour auth + base `leads`) ───────────────────────
# Dashboard : https://supabase.com/dashboard → ton projet → Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://votre-projet.supabase.co"
# Optionnel (serveur uniquement) : même URL que ci-dessus sans NEXT_PUBLIC — utilisée par /api/leads si définie
# SUPABASE_URL="https://votre-projet.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="votre-anon-key"

# Service Role (secret) — section « service_role » sur la page API, longue clé JWT commençant souvent par eyJ...
# Où l’ajouter : ici en copie de .env.example vers .env.local, OU sur Vercel → Settings → Environment Variables (Production).
# Jamais de préfixe NEXT_PUBLIC_ : cette clé ne doit jamais être exposée au navigateur.
# Sert au fallback POST /api/leads → insert dans public.leads (voir apps/web/src/lib/supabase/service-role.ts).
SUPABASE_SERVICE_ROLE_KEY=""

# URL publique de l’API Fastify (enregistrement Prisma `leads`) — requis en prod sur Vercel
# Le code lit API_URL ou NEXT_PUBLIC_API_URL (pas de variable FASTIFY_API_URL dans le repo).
# Local : http://localhost:4000
# Production : https://votre-service.railway.app (sans slash final) — jamais localhost sur Vercel
NEXT_PUBLIC_API_URL=""
# Variante serveur uniquement (évite d’exposer l’URL côté navigateur si besoin)
# API_URL=""

# Resend — https://resend.com (clé API + domaine trans-meet.com vérifié)
RESEND_API_KEY=""
# Boîte qui reçoit les notifications leads/formulaires (défaut : hello@trans-meet.com via CONTACT_EMAIL)
LEADS_EMAIL=""
# Expéditeur : adresse @domaine vérifié dans Resend (ex. noreply@trans-meet.com)
RESEND_FROM=""

# Même Postgres que l'API — active le fallback sur /api/leads si Fastify est injoignable (ex. URL API mal configurée)
# DATABASE_URL="postgresql://..."

# Webhook Zapier/Make : chaque lead est envoyé en POST vers cette URL
# Créer un scénario "Catch Webhook" sur Zapier ou Make pour obtenir l'URL
LEADS_WEBHOOK_URL=""

