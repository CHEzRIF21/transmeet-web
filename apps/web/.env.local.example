# Copier ce fichier en .env.local pour tester le site en local.
# apps/web : site vitrine + auth + dashboard (tout intégré sur localhost:3000)

# Supabase (obligatoire pour login/register/dashboard)
NEXT_PUBLIC_SUPABASE_URL="https://votre-projet.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="votre-anon-key"

# URL de l’API Fastify (requis pour enregistrer les leads en base)
# NEXT_PUBLIC_API_URL="http://localhost:4000"
# ou uniquement côté serveur : API_URL="http://localhost:4000"

# Base de données (requis pour le dashboard avec données réelles)
# Utiliser la même URL que l'API si partage de la base
# DATABASE_URL="postgresql://user:password@host:5432/transmeet"

# Resend — envoi des leads par email
# RESEND_API_KEY="re_xxx"
# LEADS_EMAIL="hello@trans-meet.com"
# Expéditeur = adresse @domaine vérifié dans Resend
# RESEND_FROM="Transmeet <noreply@trans-meet.com>"
