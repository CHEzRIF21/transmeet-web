generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ÉNUMÉRATIONS ────────────────────────────────────

enum UserRole {
  EXPEDITEUR
  TRANSPORTEUR
  ADMIN
  DOUANIER
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  BANNED
}

enum VehicleType {
  PLATEAU
  CITERNE
  FRIGO
  BENNE
  CONTENEUR
  BACHE
  MARCHANDISE
}

enum VehicleStatus {
  AVAILABLE
  ON_MISSION
  MAINTENANCE
  INACTIVE
}

enum DocStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RequestStatus {
  DRAFT
  PUBLISHED
  MATCHED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum MissionStatus {
  ASSIGNED
  LOADING
  IN_TRANSIT
  AT_CUSTOMS
  DELIVERED
  DISPUTED
}

enum DealStatus {
  NEGOTIATING
  AGREED
  PAYMENT_PENDING
  PAID
  DELIVERED
  DISPUTED
}

enum PaymentMethod {
  MOBILE_MONEY
  BANK_TRANSFER
  CARD
  ESCROW
}

enum PaymentGateway {
  CINETPAY
  STRIPE
  WAVE
}

enum PaymentStatus {
  PENDING
  HELD_ESCROW
  RELEASED
  REFUNDED
  FAILED
}

enum CustomsDossierStatus {
  INCOMPLETE
  SUBMITTED
  UNDER_REVIEW
  CLEARED
  REJECTED
}

enum MessageType {
  TEXT
  FILE
  OFFER
  SYSTEM
}

enum MessageRoomType {
  MISSION
  DEAL
  SUPPORT
}

// Spec Domaine 1 — companies.type
enum CompanyType {
  EXPEDITEUR
  TRANSPORTEUR
  NEGOCIANT
}

// Spec Domaine 1 — user_documents.type
enum UserDocumentType {
  ID_CARD
  PASSPORT
  PERMIS
  RCCM
  CARTE_GRISE
  CARTE_PROFESSIONNELLE
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
}

// Spec Domaine 2 — vehicle_docs.type
enum VehicleDocType {
  ASSURANCE
  VISITE_TECH
  CARTE_GRISE
  LAISSEZ_PASSER
}

// Spec Domaine 2 — vehicle_docs.status
enum VehicleDocStatus {
  VALID
  EXPIRING
  EXPIRED
}

// Spec Domaine 4 — notifications.channel
enum NotificationChannel {
  PUSH
  SMS
  EMAIL
  IN_APP
}

// Spec Domaine 4 — customs_documents.status (validated = APPROVED)
enum CustomsDocStatus {
  PENDING
  VALIDATED
  REJECTED
}

enum LeadType {
  EXPEDITEUR
  TRANSPORTEUR
  BTP
  CONTACT
}

// ─── TABLES ──────────────────────────────────────────
// Profile = table profiles (synchro Supabase Auth via trigger on_auth_user_created)
// id correspond à auth.users.id

model Profile {
  id         String   @id @db.Uuid
  role       String   @default("expediteur") @db.Text
  full_name  String?  @db.Text
  email      String?  @db.Text
  phone      String?  @db.Text
  avatar_url String?  @db.Text
  is_active  Boolean  @default(true)
  kyc_status String?  @default("pending") @db.Text // pending | validated | rejected
  company_id String?  @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @updatedAt @db.Timestamptz

  company             Company?           @relation("ProfileCompany", fields: [company_id], references: [id])
  ownedCompany        Company?           @relation("CompanyOwner")
  documents           UserDocument[]
  sentRequests        TransportRequest[]
  carrierMissions     Mission[]          @relation("CarrierMissions")
  offers              Offer[]            @relation("CarrierOffers")
  buyerDeals          CommercialDeal[]   @relation("BuyerDeals")
  sellerDeals         CommercialDeal[]   @relation("SellerDeals")
  paidPayments        Payment[]          @relation("PayerPayments")
  receivedPayments    Payment[]          @relation("PayeePayments")
  sentMessages        Message[]
  notifications       Notification[]
  conversationsAsExpediteur Conversation[] @relation("ExpediteurConversations")
  conversationsAsTransporteur Conversation[] @relation("TransporteurConversations")
  reviewsGiven        Review[]           @relation("ReviewsGiven")
  reviewsReceived     Review[]           @relation("ReviewsReceived")
  reviewedDocuments   UserDocument[]     @relation("ReviewedDocuments")
  uploadedCustomsDocs CustomsDocument[]  @relation("UploadedCustomsDocs")

  @@index([role])
  @@map("profiles")
}

model Company {
  id        String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId   String      @unique @db.Uuid
  name      String
  type      CompanyType
  country   String      @db.Char(3)
  taxId     String?
  address   String?     @db.Text
  verified  Boolean     @default(false)
  createdAt DateTime    @default(now()) @db.Timestamptz
  updatedAt DateTime    @updatedAt @db.Timestamptz

  owner    Profile   @relation("CompanyOwner", fields: [ownerId], references: [id])
  profiles Profile[] @relation("ProfileCompany")
  vehicles Vehicle[]

  @@map("companies")
}

model UserDocument {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String           @db.Uuid
  type           UserDocumentType
  fileUrl        String
  status         DocStatus        @default(PENDING)
  rejectionNote  String?          @db.Text
  reviewedBy     String?          @db.Uuid
  reviewedAt     DateTime?        @db.Timestamptz
  createdAt      DateTime         @default(now()) @db.Timestamptz

  user     Profile  @relation(fields: [userId], references: [id])
  reviewer Profile? @relation("ReviewedDocuments", fields: [reviewedBy], references: [id])

  @@index([userId, status])
  @@map("user_documents")
}

model Vehicle {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId    String        @db.Uuid
  plateNumber  String        @unique
  type         VehicleType
  capacityTons Decimal       @db.Decimal(10, 2)
  capacityM3   Decimal?      @db.Decimal(10, 2)
  countryReg   String        @db.Char(3)
  isAvailable  Boolean       @default(true)
  currentLat   Decimal?      @db.Decimal(10, 7)
  currentLng   Decimal?      @db.Decimal(10, 7)
  status       VehicleStatus @default(AVAILABLE)
  createdAt    DateTime      @default(now()) @db.Timestamptz
  updatedAt    DateTime      @updatedAt @db.Timestamptz

  company   Company      @relation(fields: [companyId], references: [id])
  documents VehicleDoc[]
  missions  Mission[]
  offers    Offer[]

  @@index([companyId, status])
  @@index([type, status, isAvailable])
  @@map("vehicles")
}

model VehicleDoc {
  id        String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vehicleId String           @db.Uuid
  type      VehicleDocType
  fileUrl   String
  expiresAt DateTime?        @db.Date
  status    VehicleDocStatus @default(VALID)
  createdAt DateTime         @default(now()) @db.Timestamptz

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId, expiresAt])
  @@index([vehicleId, status])
  @@map("vehicle_docs")
}

model TransportRequest {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reference     String?       @unique @db.Text
  senderId      String        @db.Uuid
  originCity    String
  originCountry String        @db.Char(3)
  destCity      String
  destCountry   String        @db.Char(3)
  goodsType     String
  weightTons    Decimal       @db.Decimal(10, 2)
  volumeM3      Decimal?      @db.Decimal(10, 2)
  pickupDate    DateTime      @db.Date
  deliveryDate  DateTime?     @db.Date
  proposedPrice Decimal       @db.Decimal(15, 0)
  currency      String        @default("XOF") @db.VarChar(5)
  status        RequestStatus @default(DRAFT)
  specialNotes  String?       @db.Text
  createdAt     DateTime      @default(now()) @db.Timestamptz
  updatedAt     DateTime      @updatedAt @db.Timestamptz

  sender   Profile   @relation(fields: [senderId], references: [id])
  missions Mission[]
  offers   Offer[]

  @@index([senderId, status])
  @@index([originCountry, destCountry, status])
  @@index([pickupDate, status])
  @@map("transport_requests")
}

model Mission {
  id                    String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reference             String?       @unique @db.Text
  requestId             String        @db.Uuid
  carrierId             String        @db.Uuid
  vehicleId             String?       @db.Uuid
  agreedPrice           Decimal       @db.Decimal(15, 0)
  commissionRate        Decimal       @default(0.05) @db.Decimal(5, 4)
  status                MissionStatus @default(ASSIGNED)
  pickupEstimatedAt     DateTime?     @db.Timestamptz
  deliveryEstimatedAt   DateTime?     @db.Timestamptz
  pickupConfirmedAt     DateTime?     @db.Timestamptz
  deliveryConfirmedAt   DateTime?     @db.Timestamptz
  trackingUpdates       Json?
  createdAt             DateTime      @default(now()) @db.Timestamptz
  updatedAt             DateTime      @updatedAt @db.Timestamptz

  request           TransportRequest @relation(fields: [requestId], references: [id])
  carrier           Profile          @relation("CarrierMissions", fields: [carrierId], references: [id])
  vehicle           Vehicle?         @relation(fields: [vehicleId], references: [id])
  linkedDeals       CommercialDeal[]
  payments          Payment[]
  customsDossiers   CustomsDossier[]
  messages          Message[]
  reviews           Review[]
  trackingPositions TrackingPosition[]
  conversations     Conversation[]

  @@index([carrierId, status])
  @@index([requestId])
  @@map("missions")
}

model Offer {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  requestId      String      @db.Uuid
  carrierId      String      @db.Uuid
  vehicleId      String?     @db.Uuid
  proposedPrice  Decimal     @db.Decimal(15, 0)
  message        String?     @db.Text
  availableDate  DateTime?   @db.Date
  status         OfferStatus @default(PENDING)
  createdAt      DateTime    @default(now()) @db.Timestamptz

  request  TransportRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  carrier  Profile          @relation("CarrierOffers", fields: [carrierId], references: [id], onDelete: Cascade)
  vehicle  Vehicle?         @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  @@unique([requestId, carrierId])
  @@index([carrierId])
  @@index([requestId])
  @@map("offers")
}

model TrackingPosition {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  missionId String   @db.Uuid
  latitude  Decimal  @db.Decimal(10, 7)
  longitude Decimal @db.Decimal(10, 7)
  speedKmh  Decimal? @db.Decimal(10, 2)
  heading  Decimal?  @db.Decimal(5, 2)
  locality String?  @db.Text
  createdAt DateTime @default(now()) @db.Timestamptz

  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@index([missionId])
  @@map("tracking_positions")
}

model Conversation {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  missionId      String?   @db.Uuid
  expediteurId   String    @db.Uuid
  transporteurId String    @db.Uuid
  createdAt      DateTime  @default(now()) @db.Timestamptz

  mission      Mission?  @relation(fields: [missionId], references: [id], onDelete: SetNull)
  expediteur   Profile   @relation("ExpediteurConversations", fields: [expediteurId], references: [id])
  transporteur Profile   @relation("TransporteurConversations", fields: [transporteurId], references: [id])
  messages     Message[]

  @@unique([missionId, expediteurId, transporteurId])
  @@index([expediteurId])
  @@index([transporteurId])
  @@map("conversations")
}

model PlatformSetting {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key         String   @unique @db.Text
  value       String   @db.Text
  description String?  @db.Text
  updatedBy   String?  @db.Uuid
  updatedAt   DateTime @default(now()) @updatedAt @db.Timestamptz

  @@map("platform_settings")
}

model CommercialDeal {
  id              String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  buyerId         String     @db.Uuid
  sellerId        String     @db.Uuid
  goodsType       String
  quantityTons    Decimal    @db.Decimal(10, 2)
  unitPrice       Decimal    @db.Decimal(15, 0)
  totalAmount     Decimal    @db.Decimal(15, 0)
  currency        String     @default("XOF") @db.VarChar(5)
  status          DealStatus @default(NEGOTIATING)
  linkedMissionId String?    @db.Uuid
  createdAt       DateTime   @default(now()) @db.Timestamptz
  updatedAt       DateTime   @updatedAt @db.Timestamptz

  buyer         Profile   @relation("BuyerDeals", fields: [buyerId], references: [id])
  seller        Profile   @relation("SellerDeals", fields: [sellerId], references: [id])
  linkedMission Mission?  @relation(fields: [linkedMissionId], references: [id])
  payments      Payment[]
  messages      Message[]

  @@index([buyerId, status])
  @@index([sellerId, status])
  @@index([linkedMissionId])
  @@map("commercial_deals")
}

model Payment {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  payerId     String         @db.Uuid
  payeeId     String         @db.Uuid
  missionId   String?        @db.Uuid
  dealId      String?        @db.Uuid
  amount      Decimal        @db.Decimal(15, 0)
  commission  Decimal        @db.Decimal(15, 0)
  method      PaymentMethod
  gateway     PaymentGateway
  gatewayTxId String?        @unique
  status      PaymentStatus  @default(PENDING)
  releasedAt  DateTime?      @db.Timestamptz
  createdAt   DateTime       @default(now()) @db.Timestamptz
  updatedAt   DateTime       @updatedAt @db.Timestamptz

  payer   Profile         @relation("PayerPayments", fields: [payerId], references: [id])
  payee   Profile         @relation("PayeePayments", fields: [payeeId], references: [id])
  mission Mission?        @relation(fields: [missionId], references: [id])
  deal    CommercialDeal? @relation(fields: [dealId], references: [id])

  @@index([payerId, status])
  @@index([missionId])
  @@index([dealId])
  @@map("payments")
}

model CustomsRequirement {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  originCountry String   @db.Char(3)
  destCountry   String   @db.Char(3)
  goodsCategory String
  requiredDocs  Json // JSONB spec: [{type, description}]
  notes         String?  @db.Text
  createdAt     DateTime @default(now()) @db.Timestamptz
  updatedAt     DateTime @updatedAt @db.Timestamptz

  dossiers CustomsDossier[]

  @@unique([originCountry, destCountry, goodsCategory])
  @@map("customs_requirements")
}

model CustomsDossier {
  id             String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  missionId      String               @db.Uuid
  requirementId  String               @db.Uuid
  status         CustomsDossierStatus @default(INCOMPLETE)
  blockedRelease Boolean              @default(false)
  submittedAt    DateTime?            @db.Timestamptz
  clearedAt      DateTime?            @db.Timestamptz
  createdAt      DateTime             @default(now()) @db.Timestamptz

  mission     Mission            @relation(fields: [missionId], references: [id])
  requirement CustomsRequirement @relation(fields: [requirementId], references: [id])
  documents   CustomsDocument[]

  @@index([missionId, status])
  @@map("customs_dossiers")
}

model CustomsDocument {
  id            String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  dossierId     String           @db.Uuid
  type          String
  fileUrl       String
  uploadedBy    String           @db.Uuid
  status        CustomsDocStatus @default(PENDING)
  rejectionNote String?          @db.Text
  uploadedAt    DateTime         @default(now()) @db.Timestamptz

  dossier  CustomsDossier @relation(fields: [dossierId], references: [id])
  uploader Profile        @relation("UploadedCustomsDocs", fields: [uploadedBy], references: [id])

  @@index([dossierId, status])
  @@index([uploadedBy])
  @@map("customs_documents")
}

model Message {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String?         @db.Uuid
  roomType       MessageRoomType  @default(MISSION)
  senderId       String          @db.Uuid
  missionId      String?         @db.Uuid
  dealId         String?         @db.Uuid
  content        String?         @db.Text
  type           MessageType     @default(TEXT)
  fileUrl        String?
  readAt         DateTime?       @db.Timestamptz
  sentAt         DateTime        @default(now()) @db.Timestamptz

  conversation Conversation?  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       Profile       @relation(fields: [senderId], references: [id])
  mission      Mission?      @relation(fields: [missionId], references: [id])
  deal         CommercialDeal? @relation(fields: [dealId], references: [id])

  @@index([conversationId, sentAt])
  @@index([missionId, sentAt])
  @@index([dealId, sentAt])
  @@index([senderId])
  @@map("messages")
}

model Notification {
  id       String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId   String              @db.Uuid
  type     String
  channel  NotificationChannel @default(IN_APP)
  title    String
  body     String              @db.Text
  linkUrl  String?             @db.Text
  metadata Json?
  readAt   DateTime?           @db.Timestamptz
  sentAt   DateTime            @default(now()) @db.Timestamptz

  user Profile @relation(fields: [userId], references: [id])

  @@index([userId, readAt])
  @@map("notifications")
}

model Review {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  missionId  String   @db.Uuid
  reviewerId String   @db.Uuid
  revieweeId String   @db.Uuid
  rating     Int      @db.SmallInt // 1–5 (spec)
  comment    String?  @db.Text
  tags       Json?
  createdAt  DateTime @default(now()) @db.Timestamptz

  mission  Mission @relation(fields: [missionId], references: [id])
  reviewer Profile @relation("ReviewsGiven", fields: [reviewerId], references: [id])
  reviewee Profile @relation("ReviewsReceived", fields: [revieweeId], references: [id])

  @@unique([missionId, reviewerId])
  @@index([revieweeId])
  @@map("reviews")
}

model Lead {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type      LeadType
  name      String
  email     String
  phone     String?
  company   String?
  message   String?  @db.Text
  metadata  Json?
  createdAt DateTime @default(now()) @db.Timestamptz

  @@index([type, createdAt])
  @@map("leads")
}
