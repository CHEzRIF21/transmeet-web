# ─── BASE DE DONNÉES ─────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/transmit?schema=public"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/transmit?schema=public"

# ─── SUPABASE ─────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ─── JWT ──────────────────────────────────────────
JWT_SECRET="changeme-minimum-32-chars-secret"
JWT_REFRESH_SECRET="changeme-minimum-32-chars-refresh"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── REDIS ────────────────────────────────────────
REDIS_URL="rediss://default:PASSWORD@HOST:PORT"

# ─── CLOUDFLARE R2 ────────────────────────────────
R2_ACCOUNT_ID="your-account-id"
R2_ACCESS_KEY_ID="your-access-key"
R2_SECRET_ACCESS_KEY="your-secret-key"
R2_BUCKET_NAME="transmit-files"
R2_PUBLIC_URL="https://files.transmit.app"

# ─── CINETPAY ─────────────────────────────────────
CINETPAY_API_KEY="your-cinetpay-api-key"
CINETPAY_SITE_ID="your-site-id"
CINETPAY_SECRET_KEY="your-secret-key"
CINETPAY_WEBHOOK_SECRET="your-webhook-secret"

# ─── STRIPE ───────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ─── SMS (TERMII) ──────────────────────────────────
TERMII_API_KEY="your-termii-key"
TERMII_SENDER_ID="Transmit"

# ─── EMAIL (RESEND) ───────────────────────────────
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@transmit.app"

# ─── SENTRY ───────────────────────────────────────
SENTRY_DSN="https://xxx@sentry.io/xxx"
NEXT_PUBLIC_SENTRY_DSN="https://xxx@sentry.io/xxx"

# ─── APP ──────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:4000"
API_URL="http://localhost:4000"
CORS_ORIGIN="http://localhost:3000"
NODE_ENV="development"
PORT=4000
